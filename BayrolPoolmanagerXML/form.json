{
  "elements": [
    { "type": "ValidationTextBox", "name": "Host", "caption": "IP-Adresse / Hostname", "placeholder": "192.168.55.23" },
    { "type": "NumberSpinner", "name": "Interval", "caption": "Messwert-Intervall Sekunden", "minimum": 0 },
    { "type": "NumberSpinner", "name": "StaticInterval", "caption": "Info-Intervall Minuten", "minimum": 0 },
    { "type": "NumberSpinner", "name": "Timeout", "caption": "HTTP Timeout Sekunden", "minimum": 1 },
    { "type": "CheckBox", "name": "AutoUpdateAfterApply", "caption": "Nach Uebernehmen sofort aktualisieren" },
    { "type": "CheckBox", "name": "DebugXml", "caption": "XML-Debug im Meldungsfenster aktivieren" },
    { "type": "CheckBox", "name": "ReadSetpoints", "caption": "Sollwerte / Grenzwerte lesen" },
    { "type": "CheckBox", "name": "ReadAlarms", "caption": "Alarme lesen" },
    { "type": "CheckBox", "name": "ReadAlarmList", "caption": "Alarmuebersicht als Text lesen" },
    {
      "type": "ExpansionPanel",
      "caption": "XML Explorer",
      "items": [
        { "type": "Label", "caption": "Freier Scan oder vordefinierte Bereiche. Snapshot A/B dient zum Erkennen geaenderter XML-Adressen nach einer Bedienhandlung am PM5." },
        { "type": "NumberSpinner", "name": "ExplorerType", "caption": "XML-Typ", "minimum": 0 },
        { "type": "NumberSpinner", "name": "ExplorerStart", "caption": "Start-ID", "minimum": 0 },
        { "type": "NumberSpinner", "name": "ExplorerEnd", "caption": "End-ID", "minimum": 0 },
        { "type": "NumberSpinner", "name": "ExplorerMaxPerRun", "caption": "Max. Abfragen je Lauf", "minimum": 1 },
        { "type": "CheckBox", "name": "ExplorerOnlyValid", "caption": "Nur gueltige XML-Antworten speichern" },
        { "type": "CheckBox", "name": "ExplorerStoreRaw", "caption": "Roh-XML im JSON speichern" }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Discovery Engine",
      "items": [
        { "type": "Label", "caption": "Systematischer Scan ueber mehrere XML-Typen. Einzel-Scan oder Scheduler mit Resume-Funktion." },
        { "type": "NumberSpinner", "name": "DiscoveryTypeStart", "caption": "Start-Typ", "minimum": 0 },
        { "type": "NumberSpinner", "name": "DiscoveryTypeEnd", "caption": "End-Typ", "minimum": 0 },
        { "type": "NumberSpinner", "name": "DiscoveryIdStart", "caption": "Start-ID", "minimum": 0 },
        { "type": "NumberSpinner", "name": "DiscoveryIdEnd", "caption": "End-ID", "minimum": 0 },
        { "type": "NumberSpinner", "name": "DiscoveryMaxPerRun", "caption": "Max. Abfragen je Discovery-Lauf", "minimum": 1 },
        { "type": "NumberSpinner", "name": "DiscoverySchedulerInterval", "caption": "Scheduler-Intervall Sekunden", "minimum": 1 },
        { "type": "CheckBox", "name": "DiscoveryOnlyValid", "caption": "Nur gueltige XML-Antworten speichern" },
        { "type": "CheckBox", "name": "DiscoveryStoreRaw", "caption": "Roh-XML speichern" }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Schreibfreigaben - sicher vorbereitet, aktuell noch kein Schreiben zum PoolManager",
      "items": [
        { "type": "Label", "caption": "Standard ist strikt read-only. Auch bei gesetzter Freigabe wird aktuell noch kein Wert geschrieben." },
        { "type": "CheckBox", "name": "EnableWritePreparation", "caption": "Schreibfunktionen grundsaetzlich vorbereiten" },
        { "type": "CheckBox", "name": "AllowWriteSetpointPH", "caption": "Sollwert pH freigeben" },
        { "type": "CheckBox", "name": "AllowWriteSetpointChlorineBromine", "caption": "Sollwert Chlor / Brom freigeben" },
        { "type": "CheckBox", "name": "AllowWriteSetpointRedox1", "caption": "Sollwert Redox 1 freigeben" },
        { "type": "CheckBox", "name": "AllowWriteSetpointRedox2", "caption": "Sollwert Redox 2 freigeben" }
      ]
    }
  ],
  "actions": [
    { "type": "Button", "caption": "Jetzt aktualisieren", "onClick": "BPMXML_Update($id);" },
    { "type": "Button", "caption": "XML Explorer starten", "onClick": "BPMXML_RunExplorer($id);" },
    { "type": "Button", "caption": "Preset: Messwerte 34.4000-4100", "onClick": "BPMXML_RunExplorerMeasurements($id);" },
    { "type": "Button", "caption": "Preset: Sollwerte 34.3000-3100", "onClick": "BPMXML_RunExplorerSetpoints($id);" },
    { "type": "Button", "caption": "Preset: Alarme 44.2000-2050", "onClick": "BPMXML_RunExplorerAlarms($id);" },
    { "type": "Button", "caption": "Snapshot A speichern", "onClick": "BPMXML_StoreSnapshotA($id);" },
    { "type": "Button", "caption": "Snapshot B speichern", "onClick": "BPMXML_StoreSnapshotB($id);" },
    { "type": "Button", "caption": "Snapshot A/B vergleichen", "onClick": "BPMXML_CompareSnapshots($id);" },
    { "type": "Button", "caption": "Discovery starten", "onClick": "BPMXML_RunDiscovery($id);" },
    { "type": "Button", "caption": "Discovery Scheduler starten / Resume", "onClick": "BPMXML_StartDiscoveryScheduler($id);" },
    { "type": "Button", "caption": "Discovery Scheduler stoppen", "onClick": "BPMXML_StopDiscoveryScheduler($id);" },
    { "type": "Button", "caption": "Discovery Batch jetzt", "onClick": "BPMXML_RunDiscoveryBatch($id);" },
    { "type": "Button", "caption": "Discovery Snapshot A", "onClick": "BPMXML_StoreDiscoverySnapshotA($id);" },
    { "type": "Button", "caption": "Discovery Snapshot B", "onClick": "BPMXML_StoreDiscoverySnapshotB($id);" },
    { "type": "Button", "caption": "Discovery A/B vergleichen", "onClick": "BPMXML_CompareDiscoverySnapshots($id);" },
    { "type": "Button", "caption": "Learning: Licht starten", "onClick": "BPMXML_StartLearningLight($id);" },
    { "type": "Button", "caption": "Learning: Filterpumpe starten", "onClick": "BPMXML_StartLearningFilterPump($id);" },
    { "type": "Button", "caption": "Learning: Heizung starten", "onClick": "BPMXML_StartLearningHeater($id);" },
    { "type": "Button", "caption": "Learning: Solar starten", "onClick": "BPMXML_StartLearningSolar($id);" },
    { "type": "Button", "caption": "Learning: Eco starten", "onClick": "BPMXML_StartLearningEco($id);" },
    { "type": "Button", "caption": "Learning: Flockmatic starten", "onClick": "BPMXML_StartLearningFlockmatic($id);" },
    { "type": "Button", "caption": "Learning: Snapshot speichern", "onClick": "BPMXML_LearningAddSnapshot($id);" },
    { "type": "Button", "caption": "Learning: Analyse starten", "onClick": "BPMXML_LearningAnalyze($id);" },
    { "type": "Button", "caption": "Learning: Zuruecksetzen", "onClick": "BPMXML_LearningReset($id);" },
    { "type": "Button", "caption": "PHP-Definition aus Scan erzeugen", "onClick": "BPMXML_GenerateDefinitionFromExplorer($id);" },
    { "type": "Button", "caption": "Explorer / Discovery Ergebnisse loeschen", "onClick": "BPMXML_ClearExplorer($id);" }
  ],
  "status": [
    { "code": 102, "icon": "active", "caption": "Instanz ist aktiv" },
    { "code": 201, "icon": "error", "caption": "Keine IP-Adresse / Hostname eingetragen" },
    { "code": 202, "icon": "error", "caption": "PoolManager nicht erreichbar oder keine gueltige XML-Antwort" }
  ]
}
